<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FnacPass — Ton produit a une vie</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --fnac-yellow: #F5A623;
  --fnac-black: #1A1A1A;
  --fnac-green: #2ECC71;
  --fnac-red: #E74C3C;
  --fnac-gray: #BDC3C7;
  --fnac-white: #FFFFFF;
  --fnac-dark: #111111;
  --fnac-card: #242424;
  --fnac-border: rgba(245,166,35,0.15);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Montserrat', sans-serif;
  background: var(--fnac-dark);
  color: var(--fnac-white);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── SPLASH SCREEN ── */
#splash {
  position: fixed; inset: 0;
  background: var(--fnac-black);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  z-index: 1000;
  transition: opacity 0.5s, transform 0.5s;
}
#splash.hide { opacity: 0; transform: scale(1.05); pointer-events: none; }
.splash-logo { font-size: 52px; font-weight: 900; color: var(--fnac-yellow); letter-spacing: -2px; }
.splash-logo span { color: var(--fnac-white); }
.splash-sub { font-size: 12px; letter-spacing: 0.2em; color: rgba(255,255,255,0.4); text-transform: uppercase; margin-top: 6px; }
.splash-bar { width: 200px; height: 3px; background: rgba(255,255,255,0.1); border-radius: 2px; margin-top: 32px; overflow: hidden; }
.splash-bar-fill { height: 100%; background: var(--fnac-yellow); border-radius: 2px; animation: load 2s ease forwards; }
@keyframes load { from { width: 0; } to { width: 100%; } }

/* ── PHONE FRAME ── */
.app-wrapper {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; padding: 20px;
  background: radial-gradient(ellipse at 50% 50%, #2a1f00 0%, var(--fnac-dark) 70%);
}
.phone {
  width: 390px; min-height: 844px;
  background: var(--fnac-black);
  border-radius: 50px;
  border: 2px solid rgba(245,166,35,0.3);
  overflow: hidden;
  position: relative;
  box-shadow: 0 0 0 8px rgba(0,0,0,0.5), 0 40px 80px rgba(0,0,0,0.8), 0 0 60px rgba(245,166,35,0.08);
}
.notch {
  width: 120px; height: 30px;
  background: var(--fnac-black);
  border-radius: 0 0 20px 20px;
  margin: 0 auto;
  position: absolute; top: 0; left: 50%; transform: translateX(-50%);
  z-index: 100;
  border: 2px solid rgba(245,166,35,0.2);
  border-top: none;
}
.status-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 28px 8px;
  font-size: 11px; font-weight: 600;
  color: rgba(255,255,255,0.7);
  font-family: 'Space Mono', monospace;
}

/* ── SCREENS ── */
.screen {
  display: none;
  flex-direction: column;
  height: calc(844px - 50px);
  overflow-y: auto;
  scrollbar-width: none;
}
.screen::-webkit-scrollbar { display: none; }
.screen.active { display: flex; }

/* ── BOTTOM NAV ── */
.bottom-nav {
  display: flex; justify-content: space-around; align-items: center;
  padding: 12px 20px 24px;
  background: var(--fnac-card);
  border-top: 1px solid var(--fnac-border);
  position: absolute; bottom: 0; left: 0; right: 0;
  z-index: 50;
}
.nav-item {
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  cursor: pointer; opacity: 0.4; transition: all 0.2s;
  background: none; border: none; color: inherit;
}
.nav-item.active { opacity: 1; }
.nav-item.active .nav-icon { background: var(--fnac-yellow); }
.nav-icon {
  width: 44px; height: 44px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.06);
  font-size: 20px; transition: all 0.2s;
}
.nav-label { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.6); }
.nav-item.active .nav-label { color: var(--fnac-yellow); }

/* ── HOME SCREEN ── */
.home-header {
  padding: 50px 24px 20px;
  background: linear-gradient(180deg, rgba(245,166,35,0.08) 0%, transparent 100%);
}
.home-greeting { font-size: 13px; color: rgba(255,255,255,0.5); font-weight: 500; }
.home-name { font-size: 26px; font-weight: 800; color: var(--fnac-white); margin-top: 2px; }
.home-name span { color: var(--fnac-yellow); }
.passport-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(245,166,35,0.15); border: 1px solid rgba(245,166,35,0.3);
  border-radius: 20px; padding: 4px 12px; margin-top: 8px;
  font-size: 11px; font-weight: 700; color: var(--fnac-yellow);
  text-transform: uppercase; letter-spacing: 0.08em;
}
.badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--fnac-green); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.3)} }

.stat-row {
  display: grid; grid-template-columns: 1fr 1fr 1fr;
  gap: 10px; padding: 16px 24px;
}
.stat-card {
  background: var(--fnac-card);
  border-radius: 16px; padding: 14px 12px;
  border: 1px solid var(--fnac-border);
  text-align: center;
}
.stat-num { font-size: 22px; font-weight: 900; color: var(--fnac-yellow); }
.stat-label { font-size: 10px; color: rgba(255,255,255,0.4); font-weight: 600; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.05em; }

.section-title {
  font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.5);
  text-transform: uppercase; letter-spacing: 0.1em;
  padding: 0 24px 12px;
}

/* ── PRODUCT CARDS ── */
.product-list { padding: 0 24px; display: flex; flex-direction: column; gap: 12px; }
.product-card {
  background: var(--fnac-card); border-radius: 20px;
  border: 1px solid var(--fnac-border);
  padding: 16px; display: flex; gap: 14px; align-items: center;
  cursor: pointer; transition: all 0.2s; position: relative; overflow: hidden;
}
.product-card::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0;
  width: 3px; background: var(--fnac-yellow);
}
.product-card.green::before { background: var(--fnac-green); }
.product-card.red::before { background: var(--fnac-red); }
.product-card:hover { transform: translateX(4px); border-color: rgba(245,166,35,0.4); }
.product-icon {
  width: 52px; height: 52px; border-radius: 14px;
  background: rgba(245,166,35,0.1); border: 1px solid rgba(245,166,35,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 24px; flex-shrink: 0;
}
.product-info { flex: 1; min-width: 0; }
.product-name { font-size: 14px; font-weight: 700; color: var(--fnac-white); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.product-meta { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 3px; }
.product-status {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 8px; border-radius: 10px; font-size: 10px; font-weight: 700;
  margin-top: 5px;
}
.status-ok { background: rgba(46,204,113,0.15); color: var(--fnac-green); }
.status-warn { background: rgba(245,166,35,0.15); color: var(--fnac-yellow); }
.status-bad { background: rgba(231,76,60,0.15); color: var(--fnac-red); }
.product-arrow { font-size: 18px; color: rgba(255,255,255,0.2); }

/* ── ALERT BANNER ── */
.alert-banner {
  margin: 0 24px 16px;
  background: rgba(231,76,60,0.12); border: 1px solid rgba(231,76,60,0.3);
  border-radius: 16px; padding: 14px 16px;
  display: flex; gap: 12px; align-items: flex-start;
}
.alert-icon { font-size: 22px; flex-shrink: 0; }
.alert-text { font-size: 12px; color: rgba(255,255,255,0.8); line-height: 1.5; }
.alert-title { font-weight: 700; color: var(--fnac-red); font-size: 13px; margin-bottom: 3px; }

/* ── QR SCANNER ── */
.scanner-screen { align-items: center; padding: 50px 24px 100px; }
.scanner-title { font-size: 24px; font-weight: 900; text-align: center; margin-bottom: 6px; }
.scanner-sub { font-size: 13px; color: rgba(255,255,255,0.4); text-align: center; margin-bottom: 32px; }
.scanner-frame {
  width: 260px; height: 260px; border-radius: 24px;
  background: var(--fnac-card); border: 2px solid var(--fnac-yellow);
  position: relative; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.scanner-line {
  position: absolute; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--fnac-yellow), transparent);
  animation: scan 2s ease-in-out infinite;
}
@keyframes scan { 0%{top:10%} 50%{top:85%} 100%{top:10%} }
.scanner-corners::before, .scanner-corners::after {
  content: ''; position: absolute;
  width: 30px; height: 30px; border-color: var(--fnac-yellow); border-style: solid;
}
.scanner-corners::before { top: 8px; left: 8px; border-width: 3px 0 0 3px; border-radius: 4px 0 0 0; }
.scanner-corners::after { bottom: 8px; right: 8px; border-width: 0 3px 3px 0; border-radius: 0 0 4px 0; }
.scanner-icon { font-size: 64px; opacity: 0.15; }

.recent-scans { width: 100%; margin-top: 28px; }
.scan-item {
  display: flex; gap: 12px; align-items: center;
  padding: 12px 16px; background: var(--fnac-card);
  border-radius: 14px; margin-bottom: 8px;
  border: 1px solid var(--fnac-border); cursor: pointer;
  transition: all 0.2s;
}
.scan-item:hover { border-color: rgba(245,166,35,0.4); }
.scan-time { font-size: 10px; color: rgba(255,255,255,0.3); font-family: 'Space Mono', monospace; margin-left: auto; }
.scan-name { font-size: 13px; font-weight: 600; }
.scan-result { font-size: 11px; color: var(--fnac-green); }

.scan-btn {
  width: 100%; padding: 16px; border-radius: 16px;
  background: var(--fnac-yellow); color: var(--fnac-black);
  border: none; font-size: 15px; font-weight: 800;
  font-family: 'Montserrat', sans-serif; cursor: pointer;
  margin-top: 20px; transition: all 0.2s;
  letter-spacing: 0.02em;
}
.scan-btn:hover { background: #e09520; transform: translateY(-1px); }
.scan-btn:active { transform: scale(0.98); }

/* ── SAV SCREEN ── */
.sav-header {
  padding: 50px 24px 20px;
}
.sav-title { font-size: 26px; font-weight: 900; }
.sav-sub { font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 4px; }

.sav-steps { padding: 0 24px; }
.sav-step {
  display: flex; gap: 16px; margin-bottom: 20px; position: relative;
}
.sav-step::after {
  content: ''; position: absolute; left: 21px; top: 44px;
  width: 2px; height: calc(100% - 10px);
  background: rgba(245,166,35,0.15);
}
.sav-step:last-child::after { display: none; }
.step-num {
  width: 44px; height: 44px; border-radius: 14px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 900;
  background: rgba(245,166,35,0.1); border: 1px solid rgba(245,166,35,0.3);
  color: var(--fnac-yellow); z-index: 1;
}
.step-num.done { background: var(--fnac-green); color: white; border-color: var(--fnac-green); }
.step-content { flex: 1; padding-top: 8px; }
.step-title { font-size: 14px; font-weight: 700; }
.step-desc { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 4px; line-height: 1.5; }

.sav-form { padding: 0 24px; }
.form-group { margin-bottom: 16px; }
.form-label { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; display: block; }
.form-select, .form-textarea {
  width: 100%; padding: 14px 16px;
  background: var(--fnac-card); border: 1px solid var(--fnac-border);
  border-radius: 14px; color: var(--fnac-white);
  font-family: 'Montserrat', sans-serif; font-size: 13px;
  appearance: none; outline: none; transition: border-color 0.2s;
}
.form-select:focus, .form-textarea:focus { border-color: rgba(245,166,35,0.5); }
.form-textarea { resize: none; height: 90px; }
.submit-btn {
  width: 100%; padding: 16px; border-radius: 16px;
  background: var(--fnac-yellow); color: var(--fnac-black);
  border: none; font-size: 15px; font-weight: 800;
  font-family: 'Montserrat', sans-serif; cursor: pointer;
  margin-top: 8px; transition: all 0.2s;
}
.submit-btn:hover { background: #e09520; }

/* ── LOOP SCREEN ── */
.loop-header {
  padding: 50px 24px 20px;
  background: linear-gradient(180deg, rgba(46,204,113,0.06) 0%, transparent 100%);
}
.loop-title { font-size: 26px; font-weight: 900; }
.loop-title span { color: var(--fnac-green); }
.loop-sub { font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 4px; }

.co2-card {
  margin: 0 24px 20px;
  background: linear-gradient(135deg, rgba(46,204,113,0.12) 0%, rgba(46,204,113,0.04) 100%);
  border: 1px solid rgba(46,204,113,0.25); border-radius: 20px;
  padding: 20px;
}
.co2-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 14px; }
.co2-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); font-weight: 700; }
.co2-score { font-size: 36px; font-weight: 900; color: var(--fnac-green); line-height: 1; }
.co2-unit { font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.5); }
.co2-bar { height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; overflow: hidden; }
.co2-fill { height: 100%; background: var(--fnac-green); border-radius: 3px; width: 73%; transition: width 1s; }
.co2-legend { display: flex; justify-content: space-between; margin-top: 6px; }
.co2-legend span { font-size: 10px; color: rgba(255,255,255,0.3); font-family: 'Space Mono', monospace; }

.loop-actions { padding: 0 24px; display: flex; flex-direction: column; gap: 10px; }
.loop-action {
  background: var(--fnac-card); border-radius: 20px;
  border: 1px solid var(--fnac-border); padding: 18px;
  display: flex; gap: 16px; align-items: center;
  cursor: pointer; transition: all 0.2s;
}
.loop-action:hover { border-color: rgba(245,166,35,0.3); transform: translateX(4px); }
.action-icon {
  width: 52px; height: 52px; border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; flex-shrink: 0;
}
.action-repair { background: rgba(245,166,35,0.12); }
.action-sell { background: rgba(46,204,113,0.12); }
.action-recycle { background: rgba(52,152,219,0.12); }
.action-info { flex: 1; }
.action-title { font-size: 15px; font-weight: 700; }
.action-desc { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 3px; }
.action-badge {
  font-size: 11px; font-weight: 700; padding: 4px 10px;
  border-radius: 10px; flex-shrink: 0;
}
.badge-yellow { background: rgba(245,166,35,0.15); color: var(--fnac-yellow); }
.badge-green { background: rgba(46,204,113,0.15); color: var(--fnac-green); }
.badge-blue { background: rgba(52,152,219,0.15); color: #3498DB; }

.points-banner {
  margin: 16px 24px 0;
  background: var(--fnac-yellow); border-radius: 16px;
  padding: 16px 20px; display: flex; justify-content: space-between; align-items: center;
}
.points-text { font-size: 13px; font-weight: 700; color: var(--fnac-black); }
.points-num { font-size: 26px; font-weight: 900; color: var(--fnac-black); font-family: 'Space Mono', monospace; }

/* ── PROFILE ── */
.profile-header {
  padding: 50px 24px 20px;
  display: flex; gap: 16px; align-items: center;
}
.avatar {
  width: 72px; height: 72px; border-radius: 22px;
  background: var(--fnac-yellow); display: flex; align-items: center;
  justify-content: center; font-size: 28px; font-weight: 900;
  color: var(--fnac-black); flex-shrink: 0;
}
.profile-name { font-size: 20px; font-weight: 800; }
.profile-email { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 3px; }
.profile-tier {
  display: inline-flex; align-items: center; gap: 5px;
  background: var(--fnac-yellow); color: var(--fnac-black);
  border-radius: 10px; padding: 3px 10px; font-size: 11px; font-weight: 800;
  margin-top: 6px; text-transform: uppercase; letter-spacing: 0.06em;
}

.profile-section { padding: 0 24px; margin-bottom: 20px; }
.profile-section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3); margin-bottom: 10px; }
.profile-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 16px; background: var(--fnac-card);
  border-radius: 14px; margin-bottom: 6px;
  border: 1px solid var(--fnac-border); cursor: pointer; transition: all 0.2s;
}
.profile-item:hover { border-color: rgba(245,166,35,0.3); }
.profile-item-left { display: flex; gap: 12px; align-items: center; }
.profile-item-icon { font-size: 18px; width: 36px; text-align: center; }
.profile-item-label { font-size: 14px; font-weight: 600; }
.profile-item-value { font-size: 12px; color: rgba(255,255,255,0.4); }
.profile-item-arrow { color: rgba(255,255,255,0.2); font-size: 14px; }

/* ── PRODUCT DETAIL MODAL ── */
.modal {
  position: absolute; inset: 0;
  background: var(--fnac-black);
  z-index: 200; display: none;
  flex-direction: column;
  animation: slideUp 0.3s ease;
}
.modal.active { display: flex; }
@keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
.modal-header {
  display: flex; align-items: center; gap: 16px;
  padding: 50px 24px 20px;
}
.back-btn {
  width: 40px; height: 40px; border-radius: 12px;
  background: var(--fnac-card); border: 1px solid var(--fnac-border);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; font-size: 16px; color: var(--fnac-white);
  flex-shrink: 0;
}
.modal-title { font-size: 20px; font-weight: 800; }
.modal-body { flex: 1; overflow-y: auto; padding: 0 24px 100px; scrollbar-width: none; }
.modal-body::-webkit-scrollbar { display: none; }

.product-hero {
  background: var(--fnac-card); border-radius: 24px;
  padding: 28px; display: flex; flex-direction: column;
  align-items: center; margin-bottom: 20px;
  border: 1px solid var(--fnac-border);
}
.product-hero-icon { font-size: 72px; margin-bottom: 16px; }
.product-hero-name { font-size: 20px; font-weight: 800; text-align: center; }
.product-hero-meta { font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 4px; }

.qr-block {
  background: white; border-radius: 16px;
  padding: 16px; display: flex; flex-direction: column; align-items: center;
  margin: 16px 0;
}
.qr-code {
  width: 120px; height: 120px;
  background: var(--fnac-black);
  border-radius: 8px; display: grid;
  grid-template-columns: repeat(7,1fr); gap: 2px; padding: 8px;
}
.qr-cell { border-radius: 1px; }
.qr-on { background: var(--fnac-black); }
.qr-off { background: transparent; }
.qr-label { font-size: 10px; color: var(--fnac-black); font-weight: 700; margin-top: 8px; font-family: 'Space Mono', monospace; }

.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
.info-cell {
  background: var(--fnac-card); border-radius: 14px;
  padding: 14px; border: 1px solid var(--fnac-border);
}
.info-cell-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.3); margin-bottom: 4px; }
.info-cell-value { font-size: 14px; font-weight: 700; }
.info-cell-value.yellow { color: var(--fnac-yellow); }
.info-cell-value.green { color: var(--fnac-green); }
.info-cell-value.red { color: var(--fnac-red); }

.history-list { display: flex; flex-direction: column; gap: 8px; }
.history-item {
  display: flex; gap: 12px; align-items: flex-start;
  padding: 12px; background: var(--fnac-card); border-radius: 14px;
  border: 1px solid var(--fnac-border);
}
.history-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
.history-dot.yellow { background: var(--fnac-yellow); }
.history-dot.green { background: var(--fnac-green); }
.history-dot.gray { background: var(--fnac-gray); }
.history-date { font-size: 10px; color: rgba(255,255,255,0.3); font-family: 'Space Mono', monospace; }
.history-event { font-size: 13px; font-weight: 600; }

.action-buttons { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 16px; }
.action-btn {
  padding: 14px; border-radius: 16px; border: none;
  font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700;
  cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 6px;
  transition: all 0.2s;
}
.action-btn-icon { font-size: 24px; }
.action-btn.primary { background: var(--fnac-yellow); color: var(--fnac-black); }
