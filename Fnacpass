        </div>
        <div class="history-item">
          <div class="history-dot green"></div>
          <div>
            <div class="history-date">25 mars 2026</div>
            <div class="history-event">✓ Diagnostic effectué — Problème écran confirmé</div>
          </div>
        </div>
        <div class="history-item">
          <div class="history-dot gray"></div>
          <div>
            <div class="history-date">24 mars 2026</div>
            <div class="history-event">📥 Dépôt en magasin — Fnac Montpellier</div>
          </div>
        </div>
